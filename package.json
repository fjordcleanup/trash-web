{
  "name": "@fjordcleanup/trash-web",
  "version": "0.0.0-development",
  "description": "Web application to view and report trash to Fjord CleanUP",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fjordcleanup/trash-web.git"
  },
  "bugs": {
    "url": "https://github.com/fjordcleanup/trash-web/issues"
  },
  "homepage": "https://trash.fjordcleanup.org",
  "author": "Markus Tacker <m@coderbyheart.com> | https://coderbyheart.com",
  "license": "MIT",
  "scripts": {
    "start": "vite",
    "build": "node --max_old_space_size=8192 ./node_modules/vite/bin/vite.js build --emptyOutDir",
    "prepare": "husky",
    "test": "node --no-warnings --experimental-transform-types --test \"!(node_modules)/**/*.spec.ts\"",
    "test:watch": "node --no-warnings --experimental-transform-types --test --watch \"!(node_modules)/**/*.spec.ts\""
  },
  "dependencies": {
    "@bifravst/from-env": "3.0.2",
    "@coderbyheart/aws-dynamodb-es-cqrs": "1.2.0",
    "@fjordcleanup/trash-proto": "npm:@jsr/fjordcleanup__trash-proto@1.1.4",
    "@sinclair/typebox": "0.34.41",
    "@smithy/protocol-http": "5.2.1",
    "@smithy/signature-v4": "5.2.1",
    "@smithy/types": "4.5.0",
    "bootstrap": "5.3.8",
    "classnames": "2.5.1",
    "date-fns": "4.1.0",
    "lucide-preact": "0.544.0",
    "leaflet": "1.9.4",
    "oidc-client-ts": "3.3.0",
    "preact": "10.27.2",
    "preact-router": "4.1.2",
    "proj4": "2.19.10",
    "ulidx": "2.4.1"
  },
  "devDependencies": {
    "@aws-sdk/client-cloudformation": "3.894.0",
    "@aws-sdk/client-cloudfront": "3.894.0",
    "@babel/plugin-syntax-import-assertions": "7.27.1",
    "@bifravst/cloudformation-helpers": "9.1.1",
    "@bifravst/eslint-config-typescript": "6.4.3",
    "@bifravst/prettier-config": "1.1.13",
    "@commitlint/config-conventional": "19.8.1",
    "@preact/preset-vite": "2.10.2",
    "@types/node": "24.5.2",
    "@types/leaflet": "1.9.20",
    "commitlint": "19.8.1",
    "glob": "11.0.3",
    "handlebars": "4.7.8",
    "husky": "9.1.7",
    "lint-staged": "16.2.0",
    "typescript": "5.9.2",
    "vite": "7.1.6"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint"
    ],
    "*.{md,json,yaml,yml,html,css}": [
      "prettier --write"
    ]
  },
  "prettier": "@bifravst/prettier-config",
  "release": {
    "branches": [
      "saga"
    ],
    "remoteTags": true,
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      [
        "@semantic-release/github",
        {
          "successCommentCondition": false,
          "failTitle": false
        }
      ]
    ]
  }
}
